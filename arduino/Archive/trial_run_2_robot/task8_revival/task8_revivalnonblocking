#include <Wire.h>
#include <Motoron.h>

// Motor controller address
MotoronI2C motorBoard(16);

// --------------------
// Motor setup
// --------------------

const int leftMotorChannel = 1;
const int rightMotorChannel = 2;

// These fix the direction of each motor
const int leftMotorDirection = 1;
const int rightMotorDirection = -1;

// --------------------
// LEDs and switches
// --------------------

const int redLedPin = 52;
const int greenLedPin = 48;

const int bumperPin = 8;

// Mechanical kill switch
// This should connect the pin to GND when pressed
const int killSwitchPin = 7;

// This will be set by the WiFi code later
// For now we can test it from Serial Monitor using K
bool wifiStopRequested = false;

// --------------------
// Distance sensor setup
// --------------------

const unsigned long distanceSensorBaud = 921600;

// Each sensor sends 16 bytes at a time
uint8_t frontSensorFrame[16];
uint8_t sideSensor2Frame[16];
uint8_t sideSensor3Frame[16];
uint8_t sideSensor4Frame[16];

// Keeps track of how many bytes we have collected so far
uint8_t frontFramePos = 0;
uint8_t sensor2FramePos = 0;
uint8_t sensor3FramePos = 0;
uint8_t sensor4FramePos = 0;

// Latest distance readings
uint32_t frontDistance = 0;
uint32_t sensor2Distance = 0;
uint32_t sensor3Distance = 0;
uint32_t sensor4Distance = 0;

// --------------------
// Revival settings
// --------------------

const unsigned long revivalTimeLimit = 60000;  // 60 seconds

// Bumper must stay pressed this long before we call it a successful revival
const unsigned long stableContactTime = 300;   // milliseconds

// P controller values for the approach
const uint32_t slowDownDistance = 140;
const int slowestSpeed = 120;
const int fastestSpeed = 350;
const float approachGain = 0.45;

int driveSpeedNow = 0;

// Used for checking stable bumper contact
unsigned long bumperPressedStartTime = 0;

// --------------------
// Robot states
// --------------------

const int STATE_APPROACHING = 0;
const int STATE_REVIVED = 1;
const int STATE_FAILED = 2;
const int STATE_KILLED = 3;

int robotState = STATE_APPROACHING;

unsigned long revivalStartTime = 0;
unsigned long lastStatusPrint = 0;

bool failedMessagePrinted = false;
bool killMessagePrinted = false;

// --------------------
// Function declarations
// --------------------

void runRevival();
int workOutApproachSpeed(uint32_t distanceMm);

void readAllDistanceSensors();
bool updateOneSensor(HardwareSerial &sensorPort,
                     uint8_t *frame,
                     uint8_t &framePos,
                     uint32_t &distanceReading);
bool sensorFrameLooksGood(uint8_t *frame);
uint32_t getDistanceFromFrame(uint8_t *frame);
void clearOldSensorData();

void checkSerialForWifiKill();
bool stopIsRequested();
void emergencyStop();

bool bumperContactIsStable();

void driveMotors(int leftSpeed, int rightSpeed);
void stopMotors();

void redLedOn();
void greenLedOn();

void printRobotStatus();

// --------------------
// Setup
// --------------------

void setup() {
  Serial.begin(115200);

  // Do not wait forever for Serial Monitor.
  // This lets the robot still run even if it is not connected to a laptop.
  delay(1000);

  Serial.println();
  Serial.println("Robot revival code starting...");
  Serial.println("Red LED means the robot is trying, failed, or stopped.");
  Serial.println("Green LED means stable bumper contact was made.");
  Serial.println("Type K in Serial Monitor to test the WiFi kill switch.");
  Serial.println();

  Wire1.begin();

  delay(500);

  motorBoard.setBus(&Wire1);
  motorBoard.reinitialize();
  motorBoard.clearResetFlag();

  motorBoard.setCommandTimeoutMilliseconds(1000);

  motorBoard.setMaxAcceleration(leftMotorChannel, 120);
  motorBoard.setMaxDeceleration(leftMotorChannel, 250);

  motorBoard.setMaxAcceleration(rightMotorChannel, 120);
  motorBoard.setMaxDeceleration(rightMotorChannel, 250);

  pinMode(redLedPin, OUTPUT);
  pinMode(greenLedPin, OUTPUT);

  pinMode(bumperPin, INPUT_PULLUP);
  pinMode(killSwitchPin, INPUT_PULLUP);

  Serial1.begin(distanceSensorBaud);
  Serial2.begin(distanceSensorBaud);
  Serial3.begin(distanceSensorBaud);
  Serial4.begin(distanceSensorBaud);

  delay(1000);

  clearOldSensorData();

  stopMotors();
  redLedOn();

  revivalStartTime = millis();

  Serial.println("Setup finished. Robot is ready.");
}

// --------------------
// Main loop
// --------------------

void loop() {
  motorBoard.resetCommandTimeout();

  checkSerialForWifiKill();

  // Kill switch always gets priority
  if (stopIsRequested()) {
    emergencyStop();
    printRobotStatus();
    return;
  }

  // Once stopped by kill switch, stay stopped
  if (robotState == STATE_KILLED) {
    stopMotors();
    redLedOn();
    printRobotStatus();
    return;
  }

  runRevival();

  printRobotStatus();
}

// --------------------
// Main robot behaviour
// --------------------

void runRevival() {
  readAllDistanceSensors();

  if (stopIsRequested()) {
    emergencyStop();
    return;
  }

  bool stableBumperContact = bumperContactIsStable();
  unsigned long timeTaken = millis() - revivalStartTime;

  if (robotState == STATE_APPROACHING) {
    redLedOn();

    if (stableBumperContact) {
      stopMotors();
      greenLedOn();

      robotState = STATE_REVIVED;

      Serial.println();
      Serial.println("REVIVAL SUCCESSFUL");
      Serial.println("Stable bumper contact made. Robot stopped.");
      Serial.println();
    }

    else if (timeTaken >= revivalTimeLimit) {
      robotState = STATE_FAILED;
    }

    else {
      driveSpeedNow = workOutApproachSpeed(frontDistance);
      driveMotors(driveSpeedNow, driveSpeedNow);
    }
  }

  else if (robotState == STATE_REVIVED) {
    stopMotors();
    greenLedOn();
  }

  else if (robotState == STATE_FAILED) {
    stopMotors();
    redLedOn();

    if (!failedMessagePrinted) {
      Serial.println();
      Serial.println("REVIVAL UNSUCCESSFUL");
      Serial.println("The other robot was not revived within 60 seconds.");
      Serial.println();

      failedMessagePrinted = true;
    }
  }

  else if (robotState == STATE_KILLED) {
    stopMotors();
    redLedOn();
  }
}

// --------------------
// Stable bumper contact check
// --------------------

bool bumperContactIsStable() {
  bool bumperPressedNow = digitalRead(bumperPin) == LOW;

  if (bumperPressedNow) {
    if (bumperPressedStartTime == 0) {
      bumperPressedStartTime = millis();
    }

    if (millis() - bumperPressedStartTime >= stableContactTime) {
      return true;
    }
  }

  else {
    bumperPressedStartTime = 0;
  }

  return false;
}

// --------------------
// P controller speed logic
// --------------------

int workOutApproachSpeed(uint32_t distanceMm) {
  // If the sensor has no reading, just creep forward slowly
  if (distanceMm == 0) {
    return -slowestSpeed;
  }

  long distanceError = distanceMm - slowDownDistance;

  if (distanceError < 0) {
    distanceError = 0;
  }

  int calculatedSpeed = slowestSpeed + (approachGain * distanceError);

  if (calculatedSpeed > fastestSpeed) {
    calculatedSpeed = fastestSpeed;
  }

  if (calculatedSpeed < slowestSpeed) {
    calculatedSpeed = slowestSpeed;
  }

  // On our robot, negative speed means forward
  return -calculatedSpeed;
}

// --------------------
// Distance sensor reading
// --------------------

void readAllDistanceSensors() {
  updateOneSensor(Serial1, frontSensorFrame, frontFramePos, frontDistance);

  if (stopIsRequested()) {
    emergencyStop();
    return;
  }

  updateOneSensor(Serial2, sideSensor2Frame, sensor2FramePos, sensor2Distance);

  if (stopIsRequested()) {
    emergencyStop();
    return;
  }

  updateOneSensor(Serial3, sideSensor3Frame, sensor3FramePos, sensor3Distance);

  if (stopIsRequested()) {
    emergencyStop();
    return;
  }

  updateOneSensor(Serial4, sideSensor4Frame, sensor4FramePos, sensor4Distance);
}

bool updateOneSensor(HardwareSerial &sensorPort,
                     uint8_t *frame,
                     uint8_t &framePos,
                     uint32_t &distanceReading) {
  while (sensorPort.available() > 0) {
    if (stopIsRequested()) {
      emergencyStop();
      return false;
    }

    uint8_t newByte = sensorPort.read();

    // First byte of a valid frame should be 0x57
    if (framePos == 0) {
      if (newByte != 0x57) {
        continue;
      }

      frame[0] = newByte;
      framePos = 1;
    }

    else {
      frame[framePos] = newByte;
      framePos++;

      if (framePos >= 16) {
        framePos = 0;

        if (sensorFrameLooksGood(frame)) {
          distanceReading = getDistanceFromFrame(frame);
          return true;
        } else {
          return false;
        }
      }
    }
  }

  return false;
}

bool sensorFrameLooksGood(uint8_t *frame) {
  if (frame[0] != 0x57) {
    return false;
  }

  if (frame[1] != 0x00 || frame[2] != 0xFF) {
    return false;
  }

  uint8_t checksum = 0;

  for (int i = 0; i < 15; i++) {
    checksum += frame[i];
  }

  if (checksum != frame[15]) {
    return false;
  }

  return true;
}

uint32_t getDistanceFromFrame(uint8_t *frame) {
  return ((uint32_t)frame[8]) |
         ((uint32_t)frame[9] << 8) |
         ((uint32_t)frame[10] << 16);
}

void clearOldSensorData() {
  while (Serial1.available()) {
    Serial1.read();
  }

  while (Serial2.available()) {
    Serial2.read();
  }

  while (Serial3.available()) {
    Serial3.read();
  }

  while (Serial4.available()) {
    Serial4.read();
  }
}

// --------------------
// Kill switch code
// --------------------

void checkSerialForWifiKill() {
  // Temporary WiFi kill test:
  // Type K in the Serial Monitor to stop the robot.
  while (Serial.available() > 0) {
    char typedChar = Serial.read();

    if (typedChar == 'K' || typedChar == 'k') {
      wifiStopRequested = true;
    }
  }
}

bool stopIsRequested() {
  bool mechanicalKillPressed = digitalRead(killSwitchPin) == LOW;

  if (mechanicalKillPressed || wifiStopRequested) {
    return true;
  }

  return false;
}

void emergencyStop() {
  stopMotors();
  redLedOn();

  robotState = STATE_KILLED;

  if (!killMessagePrinted) {
    Serial.println();
    Serial.println("EMERGENCY STOP ACTIVE");
    Serial.println("Robot stopped by kill switch.");
    Serial.println();

    killMessagePrinted = true;
  }
}

// --------------------
// Motor functions
// --------------------

void driveMotors(int leftSpeed, int rightSpeed) {
  if (stopIsRequested()) {
    emergencyStop();
    return;
  }

  motorBoard.setSpeed(leftMotorChannel, leftMotorDirection * leftSpeed);
  motorBoard.setSpeed(rightMotorChannel, rightMotorDirection * rightSpeed);
}

void stopMotors() {
  motorBoard.setSpeed(leftMotorChannel, 0);
  motorBoard.setSpeed(rightMotorChannel, 0);
  driveSpeedNow = 0;
}

// --------------------
// LED functions
// --------------------

void redLedOn() {
  digitalWrite(redLedPin, HIGH);
  digitalWrite(greenLedPin, LOW);
}

void greenLedOn() {
  digitalWrite(redLedPin, LOW);
  digitalWrite(greenLedPin, HIGH);
}

// --------------------
// Serial status printing
// --------------------

void printRobotStatus() {
  if (millis() - lastStatusPrint >= 1000) {
    Serial.print("Status: ");

    if (robotState == STATE_APPROACHING) {
      Serial.print("approaching");
    }

    else if (robotState == STATE_REVIVED) {
      Serial.print("revived");
    }

    else if (robotState == STATE_FAILED) {
      Serial.print("revival unsuccessful");
    }

    else if (robotState == STATE_KILLED) {
      Serial.print("emergency stopped");
    }

    Serial.print(" | Front distance: ");
    Serial.print(frontDistance);
    Serial.print(" mm");

    Serial.print(" | Speed: ");
    Serial.print(driveSpeedNow);

    Serial.print(" | Bumper: ");

    if (digitalRead(bumperPin) == LOW) {
      Serial.print("pressed");
    } else {
      Serial.print("not pressed");
    }

    Serial.print(" | Stable contact: ");

    bool bumperPressedNow = digitalRead(bumperPin) == LOW;
    bool contactStableNow =
      bumperPressedNow &&
      bumperPressedStartTime > 0 &&
      millis() - bumperPressedStartTime >= stableContactTime;

    if (contactStableNow) {
      Serial.print("yes");
    } else {
      Serial.print("no");
    }

    Serial.print(" | Kill switch: ");

    if (digitalRead(killSwitchPin) == LOW) {
      Serial.print("active");
    } else {
      Serial.print("off");
    }

    Serial.print(" | WiFi stop: ");

    if (wifiStopRequested) {
      Serial.print("active");
    } else {
      Serial.print("off");
    }

    Serial.print(" | Time: ");
    Serial.print((millis() - revivalStartTime) / 1000);
    Serial.println(" sec");

    lastStatusPrint = millis();
  }
}
