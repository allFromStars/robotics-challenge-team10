#include <Wire.h>#include <Motoron.h>

// Motor controllerMotoronI2C motorController(16);

// Motor channelsconst int leftMotorChannel = 1;const int rightMotorChannel = 2;

// Motor direction correctionconst int leftMotorDirection = 1;const int rightMotorDirection = -1;

// Encoder pinsconst int leftEncoderA = D2;const int leftEncoderB = D3;

const int rightEncoderA = D4;const int rightEncoderB = D5;

// Encoder countsvolatile long leftACount = 0;volatile long leftBCount = 0;volatile long rightACount = 0;volatile long rightBCount = 0;

// ======================================================// TUNE THESE VALUES// ======================================================

// Change to -1 if robot moves the wrong wayconst int driveDirection = 1;

// Tune this so the robot stops at the end of the rampconst long finishDistanceCounts = 2500;

// Starting motor powerint motorPower = 350;

// Target speed in encoder counts per secondconst float targetVelocity = 700.0;

// If straight correction makes it worse, change this to -1const int steeringPolarity = 1;

// ======================================================// FIXED SETTINGS// ======================================================

const int statusLed = D9;

const unsigned long updateTime = 100;    // update every 100 ms

const float velocityDeadband = 150.0;const int velocityStep = 5;

const int minPower = 220;const int maxPower = 500;

// Balance / straightness settingsconst int allowedDifference = 20;const int steeringGain = 3;const int maxSteeringCorrection = 180;

// Timingunsigned long startTime = 0;unsigned long lastUpdateTime = 0;unsigned long lastPrintTime = 0;

// Previous encoder countslong lastLeftAvg = 0;long lastRightAvg = 0;

// Values for printingfloat averageVelocity = 0;int leftMotorPower = 0;int rightMotorPower = 0;int steeringCorrection = 0;

bool finished = false;

void setup() {Serial.begin(115200);delay(1000);

Serial.println("Ramped incline/decline control starting...");Serial.println("Stable velocity and balance using encoder counts.");

Wire1.begin();

motorController.setBus(&Wire1);motorController.reinitialize();motorController.clearResetFlag();motorController.setCommandTimeoutMilliseconds(1000);

motorController.setMaxAcceleration(leftMotorChannel, 200);motorController.setMaxDeceleration(leftMotorChannel, 400);

motorController.setMaxAcceleration(rightMotorChannel, 200);motorController.setMaxDeceleration(rightMotorChannel, 400);

pinMode(leftEncoderA, INPUT_PULLUP);pinMode(leftEncoderB, INPUT_PULLUP);

pinMode(rightEncoderA, INPUT_PULLUP);pinMode(rightEncoderB, INPUT_PULLUP);

attachInterrupt(digitalPinToInterrupt(leftEncoderA), countLeftA, CHANGE);attachInterrupt(digitalPinToInterrupt(leftEncoderB), countLeftB, CHANGE);attachInterrupt(digitalPinToInterrupt(rightEncoderA), countRightA, CHANGE);attachInterrupt(digitalPinToInterrupt(rightEncoderB), countRightB, CHANGE);

pinMode(statusLed, OUTPUT);digitalWrite(statusLed, LOW);

stopMotors();resetEncoderCounts();

delay(2000);

startTime = millis();lastUpdateTime = millis();

Serial.println("Robot moving...");}

void loop() {motorController.resetCommandTimeout();

if (finished) {stopMotors();return;}

long leftAvg;long rightAvg;

getSideEncoderAverages(leftAvg, rightAvg);

// Use the smaller side so the robot cannot finish just because one wheel spun morelong rampProgress = min(leftAvg, rightAvg);

// Stop when the robot reaches the tuned ramp distanceif (rampProgress >= finishDistanceCounts) {stopMotors();finished = true;digitalWrite(statusLed, HIGH);

Serial.println("RAMP COMPLETE");
return;

}

if (millis() - lastUpdateTime >= updateTime) {updateVelocityAndBalance(leftAvg, rightAvg);}

printStatus();}

void updateVelocityAndBalance(long leftAvg, long rightAvg) {float dt = (millis() - lastUpdateTime) / 1000.0;

long leftChange = leftAvg - lastLeftAvg;long rightChange = rightAvg - lastRightAvg;

float leftVelocity = leftChange / dt;float rightVelocity = rightChange / dt;

averageVelocity = (leftVelocity + rightVelocity) / 2.0;

// ==================================================// STABLE VELOCITY CONTROL// Too slow = add motor power// Too fast = reduce motor power// ==================================================

if (averageVelocity < targetVelocity - velocityDeadband) {motorPower += velocityStep;}else if (averageVelocity > targetVelocity + velocityDeadband) {motorPower -= velocityStep;}

motorPower = constrain(motorPower, minPower, maxPower);

// ==================================================// BALANCE / STRAIGHT CONTROL// Left ahead = reduce left, increase right// Right ahead = increase left, reduce right// ==================================================

long difference = leftAvg - rightAvg;

if (abs(difference) > allowedDifference) {steeringCorrection = difference * steeringGain;steeringCorrection = constrain(steeringCorrection,-maxSteeringCorrection,maxSteeringCorrection);}else {steeringCorrection = 0;}

steeringCorrection = steeringCorrection * steeringPolarity;

int leftPower = motorPower - steeringCorrection;int rightPower = motorPower + steeringCorrection;

leftPower = constrain(leftPower, 0, maxPower);rightPower = constrain(rightPower, 0, maxPower);

leftMotorPower = driveDirection * leftPower;rightMotorPower = driveDirection * rightPower;

motorController.setSpeed(leftMotorChannel, leftMotorDirection * leftMotorPower);motorController.setSpeed(rightMotorChannel, rightMotorDirection * rightMotorPower);

lastLeftAvg = leftAvg;lastRightAvg = rightAvg;lastUpdateTime = millis();}

void getSideEncoderAverages(long &leftAvg, long &rightAvg) {long la;long lb;long ra;long rb;

noInterrupts();

la = leftACount;lb = leftBCount;ra = rightACount;rb = rightBCount;

interrupts();

leftAvg = (la + lb) / 2;rightAvg = (ra + rb) / 2;}

void resetEncoderCounts() {noInterrupts();

leftACount = 0;leftBCount = 0;rightACount = 0;rightBCount = 0;

interrupts();

lastLeftAvg = 0;lastRightAvg = 0;}

void stopMotors() {motorController.setSpeed(leftMotorChannel, 0);motorController.setSpeed(rightMotorChannel, 0);

leftMotorPower = 0;rightMotorPower = 0;}

void printStatus() {if (millis() - lastPrintTime >= 500) {long leftAvg;long rightAvg;

getSideEncoderAverages(leftAvg, rightAvg);

Serial.print("RUNNING");

Serial.print(" | Left avg: ");
Serial.print(leftAvg);

Serial.print(" | Right avg: ");
Serial.print(rightAvg);

Serial.print(" | Diff: ");
Serial.print(leftAvg - rightAvg);

Serial.print(" | Avg velocity: ");
Serial.print(averageVelocity);

Serial.print(" | Motor power: ");
Serial.print(motorPower);

Serial.print(" | Correction: ");
Serial.print(steeringCorrection);

Serial.print(" | Left motor: ");
Serial.print(leftMotorPower);

Serial.print(" | Right motor: ");
Serial.print(rightMotorPower);

Serial.print(" | Time: ");
Serial.print((millis() - startTime) / 1000);

Serial.println(" sec");

lastPrintTime = millis();

}}

void countLeftA() {leftACount++;}

void countLeftB() {leftBCount++;}

void countRightA() {rightACount++;}

void countRightB() {rightBCount++;}
