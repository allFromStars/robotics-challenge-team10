const uint8_t SensorCount = 6;
const uint8_t sensorPins[SensorCount] = {2, 3, 4, 5, 6, 7};
uint16_t sensorValues[SensorCount];
const uint16_t timeout = 2500; 

void readQTR_RC() {
  for (uint8_t i = 0; i < SensorCount; i++) {
    pinMode(sensorPins[i], OUTPUT);
    digitalWrite(sensorPins[i], HIGH);
  }
  delayMicroseconds(10);

  for (uint8_t i = 0; i < SensorCount; i++) {
    pinMode(sensorPins[i], INPUT);
    sensorValues[i] = timeout;
  }

  unsigned long startTime = micros();
  bool allDone = false;

  while (!allDone && (micros() - startTime < timeout)) {
    allDone = true;
    for (uint8_t i = 0; i < SensorCount; i++) {
      if (sensorValues[i] == timeout) {
        if (digitalRead(sensorPins[i]) == LOW) {
          sensorValues[i] = micros() - startTime;
        } else {
          allDone = false;
        }
      }
    }
  }
}

// Counts down, then tracks and averages readings over a full 10 seconds
unsigned long captureSurface(String surfaceName) {
  Serial.println("=========================================");
  Serial.print("NEXT SURFACE: ");
  Serial.println(surfaceName);
  Serial.println("=========================================");
  
  // 7-second countdown to align and settle the sensor
  for (int i = 7; i > 0; i--) {
    Serial.print("Align sensor now... ");
    Serial.print(i);
    Serial.println(" seconds left");
    delay(1000);
  }
  
  Serial.println("\n--> STARTING 10-SECOND LOGGING (Hold perfectly still)...");
  
  unsigned long totalSum = 0;
  unsigned long sampleCount = 0;
  unsigned long readStartTime = millis();
  
  // Take continuous readings for 10 seconds (10000ms)
  while (millis() - readStartTime < 10000) {
    readQTR_RC();
    
    // Average the middle sensors (S3 and S4) for the calibration data
    totalSum += (sensorValues[2] + sensorValues[3]) / 2;
    sampleCount++;
    delay(30); // Fast sampling for a dense 10-second data set
  }
  
  unsigned long averageValue = totalSum / sampleCount;
  
  Serial.print("DONE! 10-Second Average for ");
  Serial.print(surfaceName);
  Serial.print(": ");
  Serial.println(averageValue);
  Serial.println("\n\n");
  
  return averageValue;
}

void setup() {
  Serial.begin(115200);
  while (!Serial) { delay(10); }
  delay(1000);
  
  Serial.println("--- 10-Second Precision Calibration Sketch ---");
  Serial.println("Keep your sensor at a constant operational height.");
  Serial.println();

  // Run the sequence
  unsigned long woodVal  = captureSurface("0: WOOD SURFACE");
  delay(4000); // 4-second break to prepare for the next surface
  
  unsigned long tapeVal  = captureSurface("1: BLACK TAPE");
  delay(4000);
  
  unsigned long seedVal  = captureSurface("3: SEED IN HOLE");
  delay(4000);
  
  unsigned long emptyVal = captureSurface("2: EMPTY HOLE");

  // Print final recorded dataset
  Serial.println("=========================================");
  Serial.println("    10-SECOND PRECISION SUMMARY TABLE    ");
  Serial.println("=========================================");
  Serial.print("Wood (0): "); Serial.println(woodVal);
  Serial.print("Seed (3): "); Serial.println(seedVal);
  Serial.print("Tape (1): "); Serial.println(tapeVal);
  Serial.print("Empty(2): "); Serial.println(emptyVal);
  Serial.println("=========================================");
  Serial.println("Send me these 4 numbers when they print out!");
}

void loop() {
  // Static script, runs once on startup. 
  // Press the Reset button on your Arduino if you need to run it again.
}
