#include <Wire.h>
#include <Motoron.h>

// ======================================================
// MOTOR SETUP
// ======================================================

MotoronI2C motorController(16);

const int leftMotorChannel = 1;
const int rightMotorChannel = 2;

// One motor is mounted opposite, so right side is reversed
const int leftMotorDirection = 1;
const int rightMotorDirection = -1;

// ======================================================
// ENCODER SETUP
// ======================================================

const int leftEncoderA = D2;
const int leftEncoderB = D3;

const int rightEncoderA = D4;
const int rightEncoderB = D5;

volatile long leftACount = 0;
volatile long leftBCount = 0;
volatile long rightACount = 0;
volatile long rightBCount = 0;

// ======================================================
// ONLY TUNE THESE
// ======================================================

// Change to -1 if the robot moves the wrong way
const int driveDirection = 1;

// Set distance using encoder counts
const long targetDistanceCounts = 2500;

// Starting motor power
int motorPower = 350;

// Target encoder speed
const float targetVelocity = 700.0;

// Change to -1 if straight correction makes it curve worse
const int steeringPolarity = 1;

// ======================================================
// FIXED SETTINGS
// ======================================================

const unsigned long updateTime = 100;

const int minPower = 220;
const int maxPower = 500;

const float velocityDeadband = 150.0;
const int velocityStep = 5;

const int allowedDifference = 20;
const int steeringGain = 3;
const int maxSteeringCorrection = 180;

unsigned long lastUpdateTime = 0;
unsigned long lastPrintTime = 0;
unsigned long startTime = 0;

long lastLeftAvg = 0;
long lastRightAvg = 0;

float averageVelocity = 0;

int leftMotorPower = 0;
int rightMotorPower = 0;
int steeringCorrection = 0;

bool finished = false;

// ======================================================
// SETUP
// ======================================================

void setup() {
  Serial.begin(115200);
  delay(1000);

  Serial.println("Encoder straight driving test starting...");

  Wire1.begin();

  motorController.setBus(&Wire1);
  motorController.reinitialize();
  motorController.clearResetFlag();
  motorController.setCommandTimeoutMilliseconds(1000);

  motorController.setMaxAcceleration(leftMotorChannel, 200);
  motorController.setMaxDeceleration(leftMotorChannel, 400);

  motorController.setMaxAcceleration(rightMotorChannel, 200);
  motorController.setMaxDeceleration(rightMotorChannel, 400);

  pinMode(leftEncoderA, INPUT_PULLUP);
  pinMode(leftEncoderB, INPUT_PULLUP);
  pinMode(rightEncoderA, INPUT_PULLUP);
  pinMode(rightEncoderB, INPUT_PULLUP);

  attachInterrupt(digitalPinToInterrupt(leftEncoderA), countLeftA, CHANGE);
  attachInterrupt(digitalPinToInterrupt(leftEncoderB), countLeftB, CHANGE);
  attachInterrupt(digitalPinToInterrupt(rightEncoderA), countRightA, CHANGE);
  attachInterrupt(digitalPinToInterrupt(rightEncoderB), countRightB, CHANGE);

  stopMotors();
  resetEncoderCounts();

  delay(2000);

  startTime = millis();
  lastUpdateTime = millis();

  Serial.println("Robot moving...");
}

// ======================================================
// LOOP
// ======================================================

void loop() {
  motorController.resetCommandTimeout();

  if (finished) {
    stopMotors();
    return;
  }

  long leftAvg;
  long rightAvg;

  getEncoderAverages(leftAvg, rightAvg);

  // Use the smaller side so one wheel cannot fake the distance
  long distanceTravelled = min(leftAvg, rightAvg);

  if (distanceTravelled >= targetDistanceCounts) {
    stopMotors();
    finished = true;

    Serial.println("TARGET DISTANCE REACHED");
    return;
  }

  if (millis() - lastUpdateTime >= updateTime) {
    updateSpeedAndBalance(leftAvg, rightAvg);
  }

  printStatus();
}

// ======================================================
// SPEED + BALANCE CONTROL
// ======================================================

void updateSpeedAndBalance(long leftAvg, long rightAvg) {
  float dt = (millis() - lastUpdateTime) / 1000.0;

  long leftChange = leftAvg - lastLeftAvg;
  long rightChange = rightAvg - lastRightAvg;

  float leftVelocity = leftChange / dt;
  float rightVelocity = rightChange / dt;

  averageVelocity = (leftVelocity + rightVelocity) / 2.0;

  // -------------------------------
  // Encoder-based speed control
  // -------------------------------

  if (averageVelocity < targetVelocity - velocityDeadband) {
    motorPower += velocityStep;
  }
  else if (averageVelocity > targetVelocity + velocityDeadband) {
    motorPower -= velocityStep;
  }

  motorPower = constrain(motorPower, minPower, maxPower);

  // -------------------------------
  // Encoder-based balance control
  // -------------------------------

  long difference = leftAvg - rightAvg;

  if (abs(difference) > allowedDifference) {
    steeringCorrection = difference * steeringGain;
    steeringCorrection = constrain(
      steeringCorrection,
      -maxSteeringCorrection,
      maxSteeringCorrection
    );
  }
  else {
    steeringCorrection = 0;
  }

  steeringCorrection = steeringCorrection * steeringPolarity;

  // If left side is ahead, reduce left and increase right
  int leftPower = motorPower - steeringCorrection;
  int rightPower = motorPower + steeringCorrection;

  leftPower = constrain(leftPower, 0, maxPower);
  rightPower = constrain(rightPower, 0, maxPower);

  leftMotorPower = driveDirection * leftPower;
  rightMotorPower = driveDirection * rightPower;

  motorController.setSpeed(leftMotorChannel, leftMotorDirection * leftMotorPower);
  motorController.setSpeed(rightMotorChannel, rightMotorDirection * rightMotorPower);

  lastLeftAvg = leftAvg;
  lastRightAvg = rightAvg;
  lastUpdateTime = millis();
}

// ======================================================
// ENCODER FUNCTIONS
// ======================================================

void getEncoderAverages(long &leftAvg, long &rightAvg) {
  long la;
  long lb;
  long ra;
  long rb;

  noInterrupts();

  la = leftACount;
  lb = leftBCount;
  ra = rightACount;
  rb = rightBCount;

  interrupts();

  leftAvg = (la + lb) / 2;
  rightAvg = (ra + rb) / 2;
}

void resetEncoderCounts() {
  noInterrupts();

  leftACount = 0;
  leftBCount = 0;
  rightACount = 0;
  rightBCount = 0;

  interrupts();

  lastLeftAvg = 0;
  lastRightAvg = 0;
}

void countLeftA() {
  leftACount++;
}

void countLeftB() {
  leftBCount++;
}

void countRightA() {
  rightACount++;
}

void countRightB() {
  rightBCount++;
}

// ======================================================
// MOTOR FUNCTIONS
// ======================================================

void stopMotors() {
  motorController.setSpeed(leftMotorChannel, 0);
  motorController.setSpeed(rightMotorChannel, 0);

  leftMotorPower = 0;
  rightMotorPower = 0;
}

// ======================================================
// SERIAL PRINT
// ======================================================

void printStatus() {
  if (millis() - lastPrintTime >= 500) {
    long leftAvg;
    long rightAvg;

    getEncoderAverages(leftAvg, rightAvg);

    Serial.print("RUNNING");

    Serial.print(" | Left avg: ");
    Serial.print(leftAvg);

    Serial.print(" | Right avg: ");
    Serial.print(rightAvg);

    Serial.print(" | Diff: ");
    Serial.print(leftAvg - rightAvg);

    Serial.print(" | Avg velocity: ");
    Serial.print(averageVelocity);

    Serial.print(" | Motor power: ");
    Serial.print(motorPower);

    Serial.print(" | Correction: ");
    Serial.print(steeringCorrection);

    Serial.print(" | Left motor: ");
    Serial.print(leftMotorPower);

    Serial.print(" | Right motor: ");
    Serial.print(rightMotorPower);

    Serial.print(" | Distance: ");
    Serial.print(min(leftAvg, rightAvg));

    Serial.print(" | Time: ");
    Serial.print((millis() - startTime) / 1000);

    Serial.println(" sec");

    lastPrintTime = millis();
  }
}
